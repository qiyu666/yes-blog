---
import { Icon } from "astro-icon/components";
---
<div class="flex items-center gap-2">
    <div id="auth-container">
        <!-- 登录按钮 -->
        <button id="github-login-btn" class="flex items-center gap-2 btn-regular rounded-lg h-10 px-3 active:scale-95">
            <Icon name="fa6-brands:github" class="text-[1.2rem]"></Icon>
            <span>GitHub 登录</span>
        </button>
        
        <!-- 登录后显示 -->
        <div id="user-info" class="flex items-center gap-2 hidden">
            <img id="user-avatar" src="" alt="User Avatar" class="w-6 h-6 rounded-full" />
            <span id="user-name" class="text-sm font-medium"></span>
            <button id="logout-btn" class="text-sm text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">
                退出
            </button>
        </div>
    </div>
</div>

<script>
    // GitHub OAuth 配置
    const GITHUB_CLIENT_ID = 'Ov23liUH4oT14zlEq4c9';
    const REDIRECT_URI = 'https://blog.qiyu666.dpdns.org';
    
    // DOM 元素
    const authContainer = document.getElementById('auth-container');
    const loginBtn = document.getElementById('github-login-btn');
    const userInfo = document.getElementById('user-info');
    const userAvatar = document.getElementById('user-avatar');
    const userName = document.getElementById('user-name');
    const logoutBtn = document.getElementById('logout-btn');
    
    // 检查登录状态
    function checkAuth() {
        const user = localStorage.getItem('github_user');
        if (user) {
            const userData = JSON.parse(user);
            showUserInfo(userData);
        } else {
            showLoginButton();
        }
    }
    
    // 显示登录按钮
    function showLoginButton() {
        loginBtn.classList.remove('hidden');
        userInfo.classList.add('hidden');
    }
    
    // 显示用户信息
    function showUserInfo(userData) {
        userAvatar.src = userData.avatar_url;
        userName.textContent = userData.name || userData.login;
        loginBtn.classList.add('hidden');
        userInfo.classList.remove('hidden');
    }
    
    // 登录
    function login() {
        const githubLoginUrl = new URL('https://github.com/login/oauth/authorize');
        githubLoginUrl.searchParams.set('client_id', GITHUB_CLIENT_ID);
        githubLoginUrl.searchParams.set('redirect_uri', REDIRECT_URI);
        githubLoginUrl.searchParams.set('scope', 'user');
        
        // 打开 GitHub 登录窗口
        const width = 600;
        const height = 400;
        const left = (window.screen.width - width) / 2;
        const top = (window.screen.height - height) / 2;
        
        const popup = window.open(
            githubLoginUrl.toString(),
            'GitHub Login',
            `width=${width},height=${height},left=${left},top=${top}`
        );
        
        // 监听消息
        window.addEventListener('message', (event) => {
            if (event.origin === REDIRECT_URI) {
                if (event.data && event.data.githubUser) {
                    localStorage.setItem('github_user', JSON.stringify(event.data.githubUser));
                    showUserInfo(event.data.githubUser);
                }
                if (popup) popup.close();
            }
        });
    }
    
    // 登出
    function logout() {
        localStorage.removeItem('github_user');
        showLoginButton();
    }
    
    // 处理 URL 中的 code
    function handleOAuthCallback() {
        const url = new URL(window.location.href);
        const code = url.searchParams.get('code');
        
        if (code) {
            // 移除 URL 中的 code 参数
            url.searchParams.delete('code');
            window.history.replaceState({}, '', url.toString());
            
            // 交换 code 为 token
            fetch('https://github.com/login/oauth/access_token', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                },
                body: JSON.stringify({
                    client_id: GITHUB_CLIENT_ID,
                    client_secret: 'e4196e8749ef94344aad9c7777c34aa8022d6432',
                    code,
                    redirect_uri: REDIRECT_URI,
                }),
            })
            .then(response => response.json())
            .then(data => {
                if (data.access_token) {
                    // 获取用户信息
                    return fetch('https://api.github.com/user', {
                        headers: {
                            'Authorization': `Bearer ${data.access_token}`,
                        },
                    });
                } else {
                    throw new Error('Failed to get access token');
                }
            })
            .then(response => response.json())
            .then(userData => {
                // 保存用户信息到 localStorage
                localStorage.setItem('github_user', JSON.stringify(userData));
                
                // 通知父窗口
                if (window.opener) {
                    window.opener.postMessage({ githubUser: userData }, REDIRECT_URI);
                    window.close();
                } else {
                    // 如果不是弹窗，直接更新 UI
                    showUserInfo(userData);
                }
            })
            .catch(error => {
                console.error('GitHub login error:', error);
            });
        }
    }
    
    // 事件监听
    if (loginBtn) {
        loginBtn.addEventListener('click', login);
    }
    
    if (logoutBtn) {
        logoutBtn.addEventListener('click', logout);
    }
    
    // 初始化
    checkAuth();
    handleOAuthCallback();
</script>