---
---
<div id="chatbot-container" class="fixed bottom-8 right-8 z-[9999]">
    <!-- 聊天按钮 -->
    <button id="chatbot-toggle" class="w-16 h-16 rounded-full bg-primary text-white shadow-xl flex items-center justify-center hover:bg-primary/90 transition-all duration-300 active:scale-95 animate-pulse cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
    </button>

    <!-- 聊天窗口 -->
    <div id="chatbot-window" class="hidden fixed bottom-24 right-8 w-80 md:w-96 bg-white dark:bg-neutral-800 rounded-lg shadow-2xl border border-neutral-200 dark:border-neutral-700 overflow-hidden z-[9999]" style="max-height: 70vh;">
        <!-- 聊天头部 -->
        <div class="bg-primary text-white p-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white text-primary flex items-center justify-center font-bold">
                    Q
                </div>
                <div>
                    <h3 class="font-semibold">AI 助手</h3>
                    <p class="text-xs opacity-80">随时为你解答问题</p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button id="chatbot-close" class="text-white hover:opacity-80 cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- 聊天内容 -->
        <div id="chatbot-messages" class="p-4 h-80 overflow-y-auto space-y-4 bg-white dark:bg-neutral-800">
            <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold flex-shrink-0">
                    Q
                </div>
                <div class="bg-neutral-100 dark:bg-neutral-700 rounded-lg p-3 max-w-[80%]">
                    <p class="text-sm text-black dark:text-white">你好！我是你的 AI 助手，有什么可以帮助你的吗？</p>
                </div>
            </div>
        </div>

        <!-- 输入区域 -->
        <div class="p-4 border-t border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800">
            <form id="chatbot-form" class="flex gap-2">
                <input 
                    type="text" 
                    id="chatbot-input" 
                    class="flex-1 p-2 border border-neutral-300 dark:border-neutral-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary bg-white dark:bg-neutral-700 text-black dark:text-white"
                    placeholder="输入你的问题..."
                />
                <button 
                    type="submit" 
                    class="bg-primary text-white px-4 rounded-lg hover:bg-primary/90 transition cursor-pointer"
                >
                    发送
                </button>
            </form>
        </div>
    </div>
</div>

<script is:inline>
    // 添加消息
    function addMessage(messages, role, content) {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'flex items-start gap-3' + (role === 'user' ? ' justify-end' : '');

        if (role === 'assistant') {
            messageDiv.innerHTML = `
                <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold flex-shrink-0">
                    Q
                </div>
                <div class="bg-neutral-100 dark:bg-neutral-700 rounded-lg p-3 max-w-[80%]">
                    <p class="text-sm text-black dark:text-white">${content}</p>
                </div>
            `;
        } else {
            messageDiv.innerHTML = `
                <div class="bg-primary/10 dark:bg-primary/20 rounded-lg p-3 max-w-[80%]">
                    <p class="text-sm text-black dark:text-white">${content}</p>
                </div>
                <div class="w-8 h-8 rounded-full bg-neutral-300 dark:bg-neutral-600 text-neutral-700 dark:text-neutral-300 flex items-center justify-center font-bold flex-shrink-0">
                    U
                </div>
            `;
        }

        messages.appendChild(messageDiv);
        messages.scrollTop = messages.scrollHeight;
    }

    // 添加加载消息
    function addLoadingMessage(messages) {
        const loadingDiv = document.createElement('div');
        const id = 'loading-' + Date.now();
        loadingDiv.id = id;
        loadingDiv.className = 'flex items-start gap-3';
        loadingDiv.innerHTML = `
            <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold flex-shrink-0">
                Q
            </div>
            <div class="bg-neutral-100 dark:bg-neutral-700 rounded-lg p-3 max-w-[80%]">
                <div class="flex space-x-2">
                    <div class="w-2 h-2 rounded-full bg-neutral-400 animate-bounce" style="animation-delay: 0ms"></div>
                    <div class="w-2 h-2 rounded-full bg-neutral-400 animate-bounce" style="animation-delay: 150ms"></div>
                    <div class="w-2 h-2 rounded-full bg-neutral-400 animate-bounce" style="animation-delay: 300ms"></div>
                </div>
            </div>
        `;
        messages.appendChild(loadingDiv);
        messages.scrollTop = messages.scrollHeight;
        return id;
    }

    // 移除加载消息
    function removeLoadingMessage(id) {
        const loadingDiv = document.getElementById(id);
        if (loadingDiv) {
            loadingDiv.remove();
        }
    }

    // 初始化聊天机器人
    function initChatBot() {
        const toggle = document.getElementById('chatbot-toggle');
        const chatWindow = document.getElementById('chatbot-window');
        const close = document.getElementById('chatbot-close');
        const form = document.getElementById('chatbot-form');
        const input = document.getElementById('chatbot-input');
        const messages = document.getElementById('chatbot-messages');
        const modelSelect = document.getElementById('chatbot-model');

        // 确保所有元素都存在
        if (!toggle || !chatWindow || !close || !form || !input || !messages || !modelSelect) {
            console.error('聊天机器人元素未找到');
            return;
        }

        // 移除可能存在的旧事件监听器
        const newToggle = toggle.cloneNode(true);
        toggle.parentNode.replaceChild(newToggle, toggle);
        
        const newClose = close.cloneNode(true);
        close.parentNode.replaceChild(newClose, close);
        
        const newForm = form.cloneNode(true);
        form.parentNode.replaceChild(newForm, form);
        
        const newInput = document.getElementById('chatbot-input');
        const newMessages = document.getElementById('chatbot-messages');

        // 切换聊天窗口
        newToggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            console.log('聊天按钮被点击');
            chatWindow.classList.toggle('hidden');
            console.log('聊天窗口状态:', chatWindow.classList.contains('hidden') ? '隐藏' : '显示');
        });

        newClose.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            chatWindow.classList.add('hidden');
        });

        // 发送消息
        newForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const message = newInput.value.trim();
            if (!message) return;

            // 添加用户消息
            addMessage(newMessages, 'user', message);
            newInput.value = '';

            // 显示加载状态
            const loadingId = addLoadingMessage(newMessages);

            try {
                // 搜索本地内容
                let localContext = '';
                try {
                    const searchResponse = await fetch(`/api/content-index?q=${encodeURIComponent(message)}`);
                    if (searchResponse.ok) {
                        const searchResults = await searchResponse.json();
                        if (searchResults.length > 0) {
                            localContext = '以下是从本地博客中找到的相关内容：\n';
                            searchResults.forEach((result, index) => {
                                localContext += `${index + 1}. 标题：${result.title}\n`;
                                localContext += `   链接：/posts/${result.slug}/\n`;
                                localContext += `   摘要：${result.description || result.content.substring(0, 100)}...\n\n`;
                            });
                        }
                    }
                } catch (searchError) {
                    console.log('本地搜索失败:', searchError);
                }
                
                // 调用本地 API
                const userContent = localContext ? `${localContext}\n用户问题：${message}` : message;
                const messages = [
                    { role: 'system', content: '你是一个友好的AI博客助手，帮助用户解答关于博客、写作、技术等方面的问题。你的回答应该：1. 简洁明了，易于理解 2. 提供有价值的建议 3. 保持友好的语气 4. 如果用户问的是技术问题，可以提供代码示例' },
                    { role: 'user', content: userContent }
                ];
                
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ messages })
                });

                if (!response.ok) {
                    removeLoadingMessage(loadingId);
                    addMessage(newMessages, 'assistant', 'API错误: ' + response.statusText);
                    return;
                }

                // 处理 SSE 流式响应
                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let assistantMessage = '';
                let assistantMessageDiv = null;

                try {
                    while (true) {
                        const { done, value } = await reader.read();
                        if (done) break;

                        const chunk = decoder.decode(value, { stream: true });
                        const lines = chunk.split('\n');

                        for (const line of lines) {
                            if (line.startsWith('data: ')) {
                                const data = line.slice(6).trim();
                                if (data === '[DONE]') {
                                    break;
                                }
                                try {
                                    const parsed = JSON.parse(data);
                                    if (parsed.content) {
                                        assistantMessage += parsed.content;
                                        
                                        // 创建或更新助手消息
                                        if (!assistantMessageDiv) {
                                            assistantMessageDiv = document.createElement('div');
                                            assistantMessageDiv.className = 'flex items-start gap-3';
                                            assistantMessageDiv.innerHTML = `
                                                <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold flex-shrink-0">
                                                    Q
                                                </div>
                                                <div class="bg-neutral-100 dark:bg-neutral-700 rounded-lg p-3 max-w-[80%]">
                                                    <p class="text-sm text-black dark:text-white">${assistantMessage}</p>
                                                </div>
                                            `;
                                            newMessages.appendChild(assistantMessageDiv);
                                        } else {
                                            // 更新现有消息
                                            const contentDiv = assistantMessageDiv.querySelector('p');
                                            if (contentDiv) {
                                                contentDiv.textContent = assistantMessage;
                                            }
                                        }
                                        newMessages.scrollTop = newMessages.scrollHeight;
                                    }
                                } catch (e) {
                                    console.error('解析SSE数据错误:', e);
                                }
                            } else if (line.startsWith('data: {') && line.includes('error')) {
                                try {
                                    const parsed = JSON.parse(line.slice(6));
                                    if (parsed.error) {
                                        removeLoadingMessage(loadingId);
                                        addMessage(newMessages, 'assistant', '错误: ' + parsed.error);
                                        return;
                                    }
                                } catch (e) {
                                    console.error('解析错误数据错误:', e);
                                }
                            }
                        }
                    }
                } catch (error) {
                    console.error('读取流数据错误:', error);
                    removeLoadingMessage(loadingId);
                    addMessage(newMessages, 'assistant', '网络错误: ' + error.message);
                }

                removeLoadingMessage(loadingId);
            } catch (error) {
                console.error('请求错误:', error);
                removeLoadingMessage(loadingId);
                addMessage(newMessages, 'assistant', '网络错误: ' + error.message);
            }
        });

        // 点击外部关闭
        document.addEventListener('click', function(e) {
            const container = document.getElementById('chatbot-container');
            if (container && !container.contains(e.target)) {
                chatWindow.classList.add('hidden');
            }
        });
    }

    // 确保DOM完全加载后执行
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initChatBot);
    } else {
        initChatBot();
    }

    // 监听Swup页面切换事件，重新初始化聊天机器人
    if (window.swup) {
        window.swup.hooks.on('page:view', initChatBot);
    } else {
        document.addEventListener('swup:enable', function() {
            if (window.swup) {
                window.swup.hooks.on('page:view', initChatBot);
            }
        });
    }
</script>
