---
---
<div id="waifu-container" class="fixed bottom-4 right-4 z-[9999] flex flex-col items-end">
    <!-- 消息气泡 -->
    <div id="waifu-bubble" class="hidden mb-2 max-w-[280px] bg-white dark:bg-neutral-800 rounded-2xl rounded-br-sm shadow-lg border-2 border-pink-200 dark:border-pink-800 p-4 animate-bounce-in">
        <p id="waifu-text" class="text-sm text-neutral-700 dark:text-neutral-200">你好呀！我是你的二次元助手~ 有什么我可以帮你的吗？</p>
    </div>
    
    <!-- 聊天窗口 -->
    <div id="waifu-chat" class="hidden mb-2 w-80 md:w-96 bg-white dark:bg-neutral-800 rounded-2xl shadow-2xl border-2 border-pink-200 dark:border-pink-800 overflow-hidden">
        <!-- 头部 -->
        <div class="bg-gradient-to-r from-pink-400 to-purple-400 p-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-2xl">🌸</div>
                <div>
                    <h3 class="font-bold text-white text-sm">小樱</h3>
                    <p class="text-xs text-pink-100">在线</p>
                </div>
            </div>
            <button id="waifu-close" class="text-white hover:text-pink-200 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        
        <!-- 聊天内容 -->
        <div id="waifu-messages" class="p-3 h-64 overflow-y-auto space-y-3 bg-gradient-to-b from-pink-50 to-white dark:from-neutral-900 dark:to-neutral-800">
            <div class="flex items-start gap-2">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-300 to-purple-300 flex items-center justify-center text-sm flex-shrink-0">🌸</div>
                <div class="bg-white dark:bg-neutral-700 rounded-2xl rounded-tl-sm shadow-sm border border-pink-100 dark:border-neutral-600 p-2.5 max-w-[75%]">
                    <p class="text-xs text-neutral-700 dark:text-neutral-200">你好呀！我是小樱~ 欢迎来到我的博客！有什么我可以帮你的吗？</p>
                </div>
            </div>
        </div>
        
        <!-- 输入区域 -->
        <div class="p-3 border-t border-pink-100 dark:border-neutral-700 bg-white dark:bg-neutral-800">
            <form id="waifu-form" class="flex gap-2">
                <input 
                    type="text" 
                    id="waifu-input" 
                    class="flex-1 px-3 py-2 text-sm border border-pink-200 dark:border-neutral-600 rounded-full focus:outline-none focus:ring-2 focus:ring-pink-400 bg-pink-50 dark:bg-neutral-700 text-neutral-700 dark:text-neutral-200 placeholder-neutral-400"
                    placeholder="和小樱聊天吧..."
                />
                <button 
                    type="submit" 
                    class="w-10 h-10 bg-gradient-to-r from-pink-400 to-purple-400 text-white rounded-full hover:from-pink-500 hover:to-purple-500 transition flex items-center justify-center shadow-md"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
    
    <!-- 二次元小人 - 水手服小樱 -->
    <div id="waifu-character" class="relative cursor-pointer group">
        <!-- 悬浮提示 -->
        <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-black/70 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition whitespace-nowrap">
            点击和我聊天~
        </div>
        
        <!-- 角色容器 -->
        <div class="w-28 h-32 relative animate-float">
            <!-- 腿部 -->
            <div class="absolute bottom-0 left-1/2 -translate-x-1/2 flex gap-1">
                <div class="w-3 h-10 bg-neutral-100 rounded-full"></div>
                <div class="w-3 h-10 bg-neutral-100 rounded-full"></div>
            </div>
            
            <!-- 鞋子 -->
            <div class="absolute bottom-0 left-1/2 -translate-x-1/2 flex gap-1">
                <div class="w-3.5 h-3 bg-neutral-800 rounded-full"></div>
                <div class="w-3.5 h-3 bg-neutral-800 rounded-full"></div>
            </div>
            
            <!-- 裙子 -->
            <div class="absolute bottom-8 left-1/2 -translate-x-1/2 w-16 h-10 bg-blue-500 rounded-t-full"></div>
            <div class="absolute bottom-7 left-1/2 -translate-x-1/2 w-18 h-3 bg-blue-600 rounded-full"></div>
            
            <!-- 身体/上衣 -->
            <div class="absolute bottom-16 left-1/2 -translate-x-1/2 w-12 h-12 bg-white rounded-t-2xl"></div>
            
            <!-- 领结 -->
            <div class="absolute bottom-22 left-1/2 -translate-x-1/2 w-0 h-0 border-l-4 border-r-4 border-t-6 border-l-transparent border-r-transparent border-t-yellow-400"></div>
            
            <!-- 衣领 -->
            <div class="absolute bottom-24 left-1/2 -translate-x-1/2 w-14 h-6">
                <div class="absolute top-0 left-0 w-7 h-6 bg-blue-500 rounded-tl-full transform -rotate-12"></div>
                <div class="absolute top-0 right-0 w-7 h-6 bg-blue-500 rounded-tr-full transform rotate-12"></div>
            </div>
            
            <!-- 手臂 -->
            <div class="absolute bottom-18 -left-1 w-3 h-10 bg-white rounded-full transform -rotate-15 animate-wave"></div>
            <div class="absolute bottom-18 -right-1 w-3 h-10 bg-white rounded-full transform rotate-15 animate-wave" style="animation-delay: 0.5s"></div>
            
            <!-- 头部 -->
            <div class="absolute bottom-26 left-1/2 -translate-x-1/2 w-16 h-16 bg-neutral-100 rounded-full shadow-md">
                <!-- 眼睛 -->
                <div class="absolute top-5 left-3.5 w-3.5 h-4 bg-neutral-700 rounded-full">
                    <div class="absolute top-1 right-1 w-1.5 h-1.5 bg-white rounded-full"></div>
                </div>
                <div class="absolute top-5 right-3.5 w-3.5 h-4 bg-neutral-700 rounded-full">
                    <div class="absolute top-1 right-1 w-1.5 h-1.5 bg-white rounded-full"></div>
                </div>
                
                <!-- 腮红 -->
                <div class="absolute top-9 left-2 w-3 h-2 bg-pink-300/60 rounded-full"></div>
                <div class="absolute top-9 right-2 w-3 h-2 bg-pink-300/60 rounded-full"></div>
                
                <!-- 嘴巴 -->
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 w-2.5 h-1.5 border-b-2 border-neutral-600 rounded-full"></div>
            </div>
            
            <!-- 头发 -->
            <div class="absolute bottom-36 left-1/2 -translate-x-1/2 w-20 h-20">
                <!-- 刘海 -->
                <div class="absolute top-6 left-1/2 -translate-x-1/2 w-14 h-8 bg-amber-700 rounded-full"></div>
                <div class="absolute top-8 left-2 w-4 h-6 bg-amber-700 rounded-full transform -rotate-15"></div>
                <div class="absolute top-8 right-2 w-4 h-6 bg-amber-700 rounded-full transform rotate-15"></div>
                <!-- 侧发 -->
                <div class="absolute top-10 -left-3 w-6 h-12 bg-amber-700 rounded-full transform -rotate-6"></div>
                <div class="absolute top-10 -right-3 w-6 h-12 bg-amber-700 rounded-full transform rotate-6"></div>
            </div>
            
            <!-- 帽子 -->
            <div class="absolute bottom-38 left-1/2 -translate-x-1/2 w-18 h-8">
                <!-- 帽顶 -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-14 h-6 bg-white rounded-t-full shadow-sm"></div>
                <!-- 帽檐 -->
                <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-18 h-3 bg-white rounded-full shadow"></div>
                <!-- 蓝色条纹 -->
                <div class="absolute bottom-1 left-1/2 -translate-x-1/2 w-14 h-1.5 bg-blue-400 rounded-full"></div>
            </div>
        </div>
    </div>
</div>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }
    
    @keyframes wave {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-20deg); }
        75% { transform: rotate(20deg); }
    }
    
    @keyframes bounce-in {
        0% { transform: scale(0); opacity: 0; }
        50% { transform: scale(1.1); }
        100% { transform: scale(1); opacity: 1; }
    }
    
    .animate-float {
        animation: float 3s ease-in-out infinite;
    }
    
    .animate-wave {
        animation: wave 2s ease-in-out infinite;
    }
    
    .animate-bounce-in {
        animation: bounce-in 0.3s ease-out;
    }
</style>

<script is:inline>
    // 随机消息
    const randomMessages = [
        "你好呀！今天过得怎么样？",
        "欢迎来到我的博客~",
        "有什么我可以帮你的吗？",
        "要不要看看最新的文章？",
        "我在等你哦~",
        "点击我可以开始聊天！",
        "今天也要元气满满！",
        "有什么想聊的吗？"
    ];
    
    // 添加消息
    function addMessage(messages, role, content) {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'flex items-start gap-2' + (role === 'user' ? ' justify-end' : '');

        if (role === 'assistant') {
            messageDiv.innerHTML = `
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-300 to-purple-300 flex items-center justify-center text-sm flex-shrink-0">🌸</div>
                <div class="bg-white dark:bg-neutral-700 rounded-2xl rounded-tl-sm shadow-sm border border-pink-100 dark:border-neutral-600 p-2.5 max-w-[75%]">
                    <p class="text-xs text-neutral-700 dark:text-neutral-200">${content}</p>
                </div>
            `;
        } else {
            messageDiv.innerHTML = `
                <div class="bg-gradient-to-r from-pink-400 to-purple-400 text-white rounded-2xl rounded-tr-sm shadow-sm p-2.5 max-w-[75%]">
                    <p class="text-xs">${content}</p>
                </div>
                <div class="w-8 h-8 rounded-full bg-neutral-300 dark:bg-neutral-600 flex items-center justify-center text-sm flex-shrink-0">👤</div>
            `;
        }

        messages.appendChild(messageDiv);
        messages.scrollTop = messages.scrollHeight;
    }

    // 添加加载消息
    function addLoadingMessage(messages) {
        const loadingDiv = document.createElement('div');
        const id = 'loading-' + Date.now();
        loadingDiv.id = id;
        loadingDiv.className = 'flex items-start gap-2';
        loadingDiv.innerHTML = `
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-300 to-purple-300 flex items-center justify-center text-sm flex-shrink-0">🌸</div>
            <div class="bg-white dark:bg-neutral-700 rounded-2xl rounded-tl-sm shadow-sm border border-pink-100 dark:border-neutral-600 p-3">
                <div class="flex space-x-1">
                    <div class="w-1.5 h-1.5 rounded-full bg-pink-400 animate-bounce" style="animation-delay: 0ms"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-pink-400 animate-bounce" style="animation-delay: 150ms"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-pink-400 animate-bounce" style="animation-delay: 300ms"></div>
                </div>
            </div>
        `;
        messages.appendChild(loadingDiv);
        messages.scrollTop = messages.scrollHeight;
        return id;
    }

    // 移除加载消息
    function removeLoadingMessage(id) {
        const loadingDiv = document.getElementById(id);
        if (loadingDiv) {
            loadingDiv.remove();
        }
    }

    // 显示气泡消息
    function showBubble(text) {
        const bubble = document.getElementById('waifu-bubble');
        const bubbleText = document.getElementById('waifu-text');
        bubbleText.textContent = text;
        bubble.classList.remove('hidden');
        
        setTimeout(() => {
            bubble.classList.add('hidden');
        }, 5000);
    }

    // 初始化
    function initWaifu() {
        const character = document.getElementById('waifu-character');
        const chat = document.getElementById('waifu-chat');
        const close = document.getElementById('waifu-close');
        const form = document.getElementById('waifu-form');
        const input = document.getElementById('waifu-input');
        const messages = document.getElementById('waifu-messages');
        const bubble = document.getElementById('waifu-bubble');

        if (!character || !chat || !close || !form || !input || !messages) {
            console.error('Waifu elements not found');
            return;
        }

        // 点击角色
        character.addEventListener('click', function(e) {
            e.stopPropagation();
            bubble.classList.add('hidden');
            chat.classList.toggle('hidden');
            if (!chat.classList.contains('hidden')) {
                input.focus();
            }
        });

        // 关闭聊天
        close.addEventListener('click', function(e) {
            e.stopPropagation();
            chat.classList.add('hidden');
        });

        // 随机显示气泡
        setInterval(() => {
            if (chat.classList.contains('hidden') && bubble.classList.contains('hidden')) {
                const randomMsg = randomMessages[Math.floor(Math.random() * randomMessages.length)];
                showBubble(randomMsg);
            }
        }, 30000);

        // 发送消息
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            const message = input.value.trim();
            if (!message) return;

            addMessage(messages, 'user', message);
            input.value = '';

            const loadingId = addLoadingMessage(messages);

            try {
                // 调用API
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        messages: [
                            { role: 'system', content: '你是一个可爱的二次元少女助手，名字叫小樱。说话要活泼可爱，经常使用"~"、"呀"、"呢"等语气词。回答要简洁友好。' },
                            { role: 'user', content: message }
                        ]
                    })
                });

                if (!response.ok) {
                    removeLoadingMessage(loadingId);
                    addMessage(messages, 'assistant', '哎呀，出错了呢~ 请稍后再试吧');
                    return;
                }

                // 处理流式响应
                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let assistantMessage = '';
                let assistantMessageDiv = null;

                try {
                    while (true) {
                        const { done, value } = await reader.read();
                        if (done) break;

                        const chunk = decoder.decode(value, { stream: true });
                        const lines = chunk.split('\n');

                        for (const line of lines) {
                            if (line.startsWith('data: ')) {
                                const data = line.slice(6).trim();
                                if (data === '[DONE]') break;
                                
                                try {
                                    const parsed = JSON.parse(data);
                                    if (parsed.content) {
                                        assistantMessage += parsed.content;
                                        
                                        if (!assistantMessageDiv) {
                                            removeLoadingMessage(loadingId);
                                            assistantMessageDiv = document.createElement('div');
                                            assistantMessageDiv.className = 'flex items-start gap-2';
                                            assistantMessageDiv.innerHTML = `
                                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-300 to-purple-300 flex items-center justify-center text-sm flex-shrink-0">🌸</div>
                                                <div class="bg-white dark:bg-neutral-700 rounded-2xl rounded-tl-sm shadow-sm border border-pink-100 dark:border-neutral-600 p-2.5 max-w-[75%]">
                                                    <p class="text-xs text-neutral-700 dark:text-neutral-200">${assistantMessage}</p>
                                                </div>
                                            `;
                                            messages.appendChild(assistantMessageDiv);
                                        } else {
                                            const contentDiv = assistantMessageDiv.querySelector('p');
                                            if (contentDiv) {
                                                contentDiv.textContent = assistantMessage;
                                            }
                                        }
                                        messages.scrollTop = messages.scrollHeight;
                                    }
                                } catch (e) {
                                    console.error('Parse error:', e);
                                }
                            }
                        }
                    }
                } catch (error) {
                    console.error('Stream error:', error);
                    removeLoadingMessage(loadingId);
                    addMessage(messages, 'assistant', '网络出错了呢~ 请稍后再试吧');
                }
            } catch (error) {
                console.error('Request error:', error);
                removeLoadingMessage(loadingId);
                addMessage(messages, 'assistant', '网络出错了呢~ 请稍后再试吧');
            }
        });

        // 点击外部关闭
        document.addEventListener('click', function(e) {
            const container = document.getElementById('waifu-container');
            if (container && !container.contains(e.target)) {
                chat.classList.add('hidden');
            }
        });
    }

    // 初始化
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWaifu);
    } else {
        initWaifu();
    }

    // Swup支持
    if (window.swup) {
        window.swup.hooks.on('page:view', initWaifu);
    } else {
        document.addEventListener('swup:enable', function() {
            if (window.swup) {
                window.swup.hooks.on('page:view', initWaifu);
            }
        });
    }
</script>